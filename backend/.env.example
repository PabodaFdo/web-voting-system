# ──────────────────────────────────────────────
# BrightVote Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Spring Boot reads these from the shell / hosting platform.
# Do NOT commit .env files with real secrets.

# ── Server ────────────────────────────────────
PORT=8080

# ── Database (H2 default for local dev) ───────
SPRING_DATASOURCE_URL=jdbc:h2:file:../data/testdb;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# ── JWT Authentication ────────────────────────
# Use a long, random string (min 32 chars) in production.
APP_JWT_SECRET=your_jwt_secret_here_change_me_in_production

# ── Email / SMTP ──────────────────────────────
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM_ADDRESS=no-reply@example.com
APP_MAIL_FROM_NAME=The Bright Future Student Awards Voting Portal
