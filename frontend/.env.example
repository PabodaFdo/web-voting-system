# ──────────────────────────────────────────────
# BrightVote Frontend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env to override defaults.
# Vite exposes only VITE_* variables to the browser.

# ── API Connection ────────────────────────────
# Base URL for the Spring Boot backend
VITE_API_BASE=http://localhost:8080
VITE_API_URL=http://localhost:8080

# ── Routing ───────────────────────────────────
# Public landing page path
VITE_PUBLIC_HOME=/

# Admin dashboard base path
VITE_ADMIN_DASHBOARD_URL=/admin

# Full URL of this frontend (used for links in emails, etc.)
VITE_VOTING_URL=http://localhost:5173

# ── Voting ────────────────────────────────────
# API path for vote submission
VITE_VOTES_PATH=/api/vote

# Set to 1 to show a review step before submitting votes
VITE_REVIEW_BEFORE_SUBMIT=0
