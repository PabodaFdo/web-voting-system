# Bright Future .gitignore

# Environment and local secrets
.env
.env.*
**/.env
**/.env.*
!**/.env.example
application-local.yml
application-*.local.yml

# Java, Maven, and Spring
target/
**/target/
*.class
*.jar
*.war
*.ear
*.log
logs/
hs_err_pid*
replay_pid*
*.hprof
**/.mvn/wrapper/maven-wrapper.jar
HELP.md

# Node, Vite, and npm
node_modules/
**/node_modules/
dist/
**/dist/
.vite/
**/.vite/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local H2 database files
data/*.db
data/*.mv.db
data/*.trace.db
data/*.lock.db

# Backups and temporary files
backups/
*.bak
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs and editors
.vscode/
.idea/
*.iws
*.iml
*.ipr
*.swp
*~
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# GitHub and modernization scratch files
# Keep real GitHub config commit-able, but ignore modernization scratch work.
!.github/
!.github/**
/.github/modernize/

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# Old project directories
# These old folders were from the pre-refactor multi-app layout.
# Block them so they are never accidentally re-added.
/Nominee-frontend/
/Notification-frontend/
/Results-frontend/
/admin-frontend/
/dashboard-frontend/
/voting-frontend/
/src/main/
/src/test/
